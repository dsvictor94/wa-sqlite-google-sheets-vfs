{
  "name": "wa-sqlite-google-sheets-vfs",
  "version": "0.1.0",
  "description": "Use Google Sheets as a browser-native storage backend for SQLite via wa-sqlite VFS.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "vite build",
    "build:lib": "tsc -p tsconfig.json",
    "preview": "vite preview",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "wa-sqlite": ">=1.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "typescript": "^5.5.0",
    "vite": "^7.0.0",
    "wa-sqlite": "^1.0.0"
  }
}
